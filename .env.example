# EmailJS Configuration
# Get your credentials at https://www.emailjs.com/
# 
# Instructions:
# 1. Create an account at https://www.emailjs.com/
# 2. Add an email service (Gmail, Outlook, etc.)
# 3. Create an email template with variables: {{from_name}}, {{from_email}}, {{message}}, {{to_name}}
# 4. Copy your Service ID, Template ID, and Public Key
# 5. Paste them below (replace the placeholder values)

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=cudowna_doniczka
JWT_SECRET=minimum_32_chars_random_string
ADMIN_PASSWORD=your_admin_password
NODE_ENV=development
